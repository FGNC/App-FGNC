<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             x:Class="App_FGNC.Views.LoginPage">

    <VerticalStackLayout Padding="30">

        <Entry x:Name="txtUsuario" Placeholder="Usuário"/>
        <Entry x:Name="txtSenha" Placeholder="Senha" IsPassword="True"/>

        <Button Text="Entrar" Clicked="OnLoginClicked"/>

        <Label x:Name="lblMensagem" TextColor="Red"/>

    </VerticalStackLayout>
</ContentPage>
